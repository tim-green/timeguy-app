---
import Base from "../layouts/Base.astro";
import LiveClock from "../components/LiveClock";
import WorldBoard from "../components/WorldBoard";
import Converter from "../components/Converter";

// Server-rendered default before the client detects the real local
// timezone — keeps the hero meaningful even with JS disabled or slow.
const fallbackTz = "UTC";
const fallbackLabel = "Coordinated Universal Time";
---

<Base title="Time Guy">
  <header class="site-header">
    <div class="site-header__mark">
      <span class="site-header__glyph" aria-hidden="true">◷</span>
      <span class="site-header__name">Time Guy</span>
    </div>
    <p class="site-header__tag">Just the time, everywhere. Inspired by Time.is</p>
  </header>

  <main class="page">
    <section class="hero" aria-label="Current time">
      <LiveClock client:load initialTz={fallbackTz} initialLabel={fallbackLabel} />
    </section>

    <div class="rule" aria-hidden="true"></div>

    <section class="grid" aria-label="World clock board and timezone converter">
      <WorldBoard client:load />
      <Converter client:load />
    </section>

    <footer class="site-footer">
      <p>
        Time Guy was built on the IANA time zone database via your browser's own <code>Intl</code> engine.
      </p>
      <p>
        App name inspired by <a href="https://youtu.be/4MeCTZxumWo?si=-zMrhMquOXur6XCh&t=2126">RT Podcast No. 424</a>
        by Rooster Teeth.
      </p>
    </footer>
  </main>

  <style>
    .site-header {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.4rem;
      padding: 2rem 1.5rem 0;
    }

    .site-header__mark {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .site-header__glyph {
      color: var(--brass);
      font-size: 3rem;
      display: none;
    }

    .site-header__name {
      background-image: linear-gradient(180deg, var(--bone-dim), var(--bone));
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      font-family: var(--font-display);
      font-size: 2.5rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: bold;
      color: var(--bone-dim);
    }

    .site-header__tag {
      margin: 0;
      font-size: 0.8rem;
      color: var(--slate);
    }

    .page {
      max-width: 1080px;
      margin: 0 auto;
      padding: 0 1.5rem 4rem;
    }

    .hero {
      display: flex;
      justify-content: center;
    }

    .rule {
      height: 1px;
      background: linear-gradient(
        to right,
        transparent,
        var(--hairline) 20%,
        var(--brass) 50%,
        var(--hairline) 80%,
        transparent
      );
      margin: 0 0 2.5rem;
    }

    .grid {
      display: grid;
      grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
      gap: 1.5rem;
      align-items: stretch;
    }

    .site-footer {
      margin-top: 3rem;
      text-align: center;
      color: var(--slate);
      font-size: 0.78rem;
    }

    .site-footer code {
      font-family: var(--font-mono);
      color: var(--bone-dim);
    }

    @media (max-width: 860px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Base>
